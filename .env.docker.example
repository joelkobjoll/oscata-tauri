# Copia este fichero a .env.docker y ajusta los valores.

# Imagen y contenedor
IMAGE_NAME=oscata:local
CONTAINER_NAME=oscata

# Rutas del host montadas en el contenedor
CONFIG_DIR=/path/to/oscata-config
DOWNLOADS_DIR=/path/to/oscata-downloads

# Puerto publicado en el host
WEBGUI_HOST_PORT=47860

# Puerto interno del contenedor (cambia solo si necesitas modificar el puerto de escucha interno)
WEBGUI_CONTAINER_PORT=47860
