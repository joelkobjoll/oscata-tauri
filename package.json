{
  "name": "oscata-tauri",
  "private": true,
  "version": "0.8.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "webui:watch": "vite build --watch",
    "verify:seed-db": "node ./scripts/verify-seed-sanitized.mjs",
    "build": "npm run verify:seed-db && tsc && vite build",
    "build:portable:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-portable-windows.ps1",
    "preview": "vite preview",
    "docker:build": "bash ./scripts/docker.sh build",
    "docker:run": "bash ./scripts/docker.sh run",
    "docker:up": "bash ./scripts/docker.sh up",
    "docker:stop": "bash ./scripts/docker.sh stop",
    "docker:logs": "bash ./scripts/docker.sh logs",
    "tauri": "tauri",
    "app:dev": "tauri dev",
    "seed-db": "node ./scripts/update-starter-db.mjs",
    "seed-sync": "node ./scripts/sync-local-db-from-seed.mjs",
    "release": "node ./scripts/publish.mjs",
    "release:patch": "node ./scripts/publish.mjs patch",
    "release:minor": "node ./scripts/publish.mjs minor",
    "release:major": "node ./scripts/publish.mjs major"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}