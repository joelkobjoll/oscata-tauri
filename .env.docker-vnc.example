# Copy this file to .env.docker-vnc and adjust values for your machine.

# Image/container
IMAGE_NAME=oscata-vnc:local
CONTAINER_NAME=oscata-vnc

# Host paths mounted into the container
CONFIG_DIR=/mnt/user/appdata/oscata-vnc
DOWNLOADS_DIR=/mnt/user/data/downloads/oscata

# Published ports
VNC_PORT=5900
NOVNC_PORT=6080
WEBGUI_PORT=47860

# Optional VNC password (leave empty to disable password)
VNC_PASSWORD=

# Runtime settings
VNC_RESOLUTION=1440x960
OSCATA_BOOTSTRAP_WEBGUI=1
