<?xml version="1.0"?>
<Container version="2">
  <Name>oscata</Name>
  <Repository>oscata</Repository>
  <Registry>https://hub.docker.com/\</Registry\>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>Oscata — gestor de biblioteca multimedia con descarga automática vía FTP y metadatos TMDB. Modo headless: acceso exclusivamente por navegador web.</Overview>
  <Category>MediaApp:Tools</Category>
  <WebUI>http://\[IP\]:\[PORT:47860\]\</WebUI\>
  <TemplateURL/>
  <Icon/>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Runs Oscata in headless mode with the built-in web UI exposed on port 47860. No VNC or desktop environment required.</Description>

  <Config Name="AppData" Target="/config" Default="/mnt/user/appdata/oscata" Mode="rw" Description="App data: SQLite DB, configuration, cache" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/oscata</Config>
  <Config Name="Downloads" Target="/downloads" Default="/mnt/user/data/downloads/oscata" Mode="rw" Description="Download target directory" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/data/downloads/oscata</Config>

  <Config Name="WebGUI" Target="47860" Default="47860" Mode="tcp" Description="Oscata web UI port" Type="Port" Display="always" Required="true" Mask="false">47860</Config>

  <Config Name="OSCATA_WEBGUI_EXPOSED_PORT" Target="OSCATA_WEBGUI_EXPOSED_PORT" Default="47860" Mode="" Description="Externally visible port (for reverse-proxy setups)" Type="Variable" Display="advanced" Required="false" Mask="false">47860</Config>
  <Config Name="OSCATA_WEBGUI_APP_URL" Target="OSCATA_WEBGUI_APP_URL" Default="" Mode="" Description="Optional external URL for email invite links" Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="OSCATA_WEBGUI_OTP_ENABLED" Target="OSCATA_WEBGUI_OTP_ENABLED" Default="0" Mode="" Description="Require email OTP on login" Type="Variable" Display="advanced" Required="false" Mask="false">0</Config>
</Container>
