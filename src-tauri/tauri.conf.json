{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oscata-tauri",
  "version": "../package.json",
  "identifier": "com.oscata.media",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "oscata-tauri",
        "titleBarStyle": "Visible",
        "backgroundColor": "#0d0d0f",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}